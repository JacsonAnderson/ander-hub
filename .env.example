# .env.example - Copie para .env e preencha os valores
# NUNCA commite o arquivo .env no git!

# Segredo para assinar os tokens JWT
JWT_SECRET=troque_por_uma_chave_secreta_forte

# Senha inicial do admin (usada no seed)
ADMIN_PASS=Ander@2024

# Nome do bucket do Firebase Storage
# Encontre em: Firebase Console → Storage → aba "Files" → nome no topo (ex: meu-projeto.appspot.com)
FIREBASE_STORAGE_BUCKET=SEU_PROJETO.appspot.com

# Para produção: cole o JSON completo da conta de serviço em uma linha
# Gere em: Firebase Console → Configurações do projeto → Contas de serviço → Gerar nova chave privada
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Porta local (opcional, padrão: 3000)
PORT=3000
